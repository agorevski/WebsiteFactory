---
import { listThemes, themeClassNames, themeCssText } from '@website-factory/themes';
import SiteLayout from '../layouts/SiteLayout.astro';
import { getExampleSites } from '../lib/examples';
import { getTemplatePrototypes } from '../lib/templatePrototypes';

const sites = await getExampleSites();
const styleCards = listThemes()
  .map((theme) => ({
    id: theme.id,
    displayName: theme.displayName,
    description: theme.description,
    defaultMode: theme.defaultMode,
    tags: theme.tags,
    className: ['card', 'style-card', ...themeClassNames(theme, theme.defaultMode)].join(' '),
    cssText: themeCssText(theme, theme.defaultMode),
    heroLayout: theme.tokens.hero.layout,
    mediaShape: theme.tokens.hero.mediaShape,
    navigationLayout: theme.tokens.navigation.layout,
    navigationIndicator: theme.tokens.navigation.activeIndicator,
    footerLayout: theme.tokens.footer.layout,
    footerDensity: theme.tokens.footer.density,
    cardRadius: theme.tokens.cards.standard.radius,
    visualLabel: `${theme.displayName} theme preview using ${theme.tokens.hero.layout} hero, ${theme.tokens.hero.mediaShape} media, and ${theme.tokens.navigation.layout} navigation tokens.`
  }))
  .sort((left, right) => left.displayName.localeCompare(right.displayName));
const templateCards = [...getTemplatePrototypes()].sort((left, right) => left.name.localeCompare(right.name));

function templateCardClassName(templateCard: TemplatePrototype): string {
  return ['card', 'template-card', ...templateCard.theme.classNames].join(' ');
}

function templateCardStyle(templateCard: TemplatePrototype): string {
  return [
    templateCard.theme.cssText,
    `--template-section-count: ${templateCard.sections.length};`,
    `--template-required-ratio: ${templateCard.visual.requiredRatio.toFixed(3)};`
  ].join('\n');
}
---
<SiteLayout
  title="Website Factory Tailnet Preview"
  description="Phone-friendly catalog of generated websites, templates, and registered Website Factory styles."
>
  <main class="builder-index">
    <section class="section-pad hero builder-hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Tailnet preview hub</p>
          <h1>View every published site, template, and style from your phone.</h1>
          <p class="lede">
            Browse generated websites, registered templates, and style tokens from any device on your tailnet.
            The builder server is configured for port 3434 and binds to your machine's Tailscale address.
          </p>
          <div class="button-row">
            <a class="button button-primary" href="#websites">Open websites</a>
            <a class="button button-secondary" href="#styles">Browse styles</a>
            <a class="button button-secondary" href="#templates">View templates</a>
          </div>
        </div>
        <aside class="hero-card preview-card">
          <span class="theme-pill">Phone preview</span>
          <h2>Port 3434</h2>
          <p>
            Start the builder, then open this machine's Tailscale hostname or tailnet IP with port 3434 on your phone.
          </p>
          <dl class="hub-metrics">
            <div>
              <dt>Websites</dt>
              <dd>{sites.length}</dd>
            </div>
            <div>
              <dt>Styles</dt>
              <dd>{styleCards.length}</dd>
            </div>
            <div>
              <dt>Templates</dt>
              <dd>{templateCards.length}</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <section class="section-pad" id="websites">
      <div class="container">
        <div class="section-intro">
          <p class="eyebrow">Published websites</p>
          <h2>Every validated YAML site in one phone-friendly list</h2>
          <p>Each card links to a static page generated from `examples/**/website.yaml`.</p>
        </div>
        <div class="catalog-grid">
          {sites.map((site) => (
            <article class="card catalog-card">
              <p class="eyebrow">{site.vertical}</p>
              <h3>{site.business.name}</h3>
              <p>{site.business.tagline}</p>
              <dl class="compact-meta">
                <div>
                  <dt>Slug</dt>
                  <dd>{site.slug}</dd>
                </div>
                <div>
                  <dt>Theme</dt>
                  <dd>{site.theme.name}</dd>
                </div>
              </dl>
              <div class="button-row card-actions">
                <a class="button button-primary" href={`/${site.slug}/`}>Open site</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-pad section-alt" id="styles">
      <div class="container">
        <div class="section-intro">
          <p class="eyebrow">Style catalog</p>
          <h2>All registered Website Factory styles</h2>
          <p>These cards render with each theme's own default color tokens so you can compare palettes on mobile.</p>
        </div>
        <div class="style-grid">
          {styleCards.map((styleCard) => (
            <article
              id={`style-${styleCard.id}`}
              class={styleCard.className}
              style={styleCard.cssText}
              data-hero-layout={styleCard.heroLayout}
              data-media-shape={styleCard.mediaShape}
              data-nav-layout={styleCard.navigationLayout}
              data-nav-indicator={styleCard.navigationIndicator}
              data-footer-layout={styleCard.footerLayout}
              data-footer-density={styleCard.footerDensity}
            >
              <div class="style-preview" role="img" aria-label={styleCard.visualLabel}>
                <div class="style-preview-nav" aria-hidden="true">
                  <span class="style-preview-brand"></span>
                  <span class="style-preview-link style-preview-link-active"></span>
                  <span class="style-preview-link"></span>
                  <span class="style-preview-cta"></span>
                </div>
                <div class="style-preview-hero" aria-hidden="true">
                  <div class="style-preview-copy">
                    <span class="style-preview-eyebrow"></span>
                    <span class="style-preview-title"></span>
                    <span class="style-preview-line"></span>
                    <span class="style-preview-line style-preview-line-short"></span>
                    <span class="style-preview-button"></span>
                  </div>
                  <div class="style-preview-media">
                    <span></span>
                    <span></span>
                    <span></span>
                  </div>
                </div>
                <div class="style-preview-card-row" aria-hidden="true">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
                <div class="style-preview-footer" aria-hidden="true">
                  <span></span>
                  <span></span>
                </div>
              </div>
              <p class="eyebrow">{styleCard.id}</p>
              <h3>{styleCard.displayName}</h3>
              <p>{styleCard.description}</p>
              <dl class="compact-meta">
                <div>
                  <dt>Default mode</dt>
                  <dd>{styleCard.defaultMode}</dd>
                </div>
                <div>
                  <dt>Hero</dt>
                  <dd>{styleCard.heroLayout} · {styleCard.mediaShape}</dd>
                </div>
                <div>
                  <dt>Navigation</dt>
                  <dd>{styleCard.navigationLayout} · {styleCard.navigationIndicator}</dd>
                </div>
                <div>
                  <dt>Card radius</dt>
                  <dd>{styleCard.cardRadius}</dd>
                </div>
                <div>
                  <dt>Footer</dt>
                  <dd>{styleCard.footerLayout} · {styleCard.footerDensity}</dd>
                </div>
              </dl>
              <ul class="tag-list" aria-label={`${styleCard.displayName} tags`}>
                {styleCard.tags.slice(0, 4).map((tag) => <li>{tag}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section-pad" id="templates">
      <div class="container">
        <div class="section-intro">
          <p class="eyebrow">Template catalog</p>
          <h2>All registered Website Factory templates</h2>
          <p>Templates come directly from the shared registry and summarize their intended audience, layout rhythm, and required content coverage.</p>
        </div>
        <div class="template-grid">
          {templateCards.map((templateCard) => (
            <article
              id={`template-${templateCard.id}`}
              class={templateCardClassName(templateCard)}
              style={templateCardStyle(templateCard)}
              data-layout={templateCard.visual.layout}
              data-audience={templateCard.visual.audience}
              data-hero-layout={templateCard.visual.heroLayout}
              data-media-shape={templateCard.visual.mediaShape}
              data-nav-layout={templateCard.visual.navigationLayout}
              data-footer-layout={templateCard.visual.footerLayout}
              data-footer-density={templateCard.visual.footerDensity}
            >
              <div class="template-wireframe" role="img" aria-label={templateCard.rhythmLabel}>
                <div class="template-art-nav" aria-hidden="true">
                  <span class="template-art-brand"></span>
                  <span></span>
                  <span></span>
                  <span class="template-art-cta"></span>
                </div>
                <div class="template-art-hero" aria-hidden="true">
                  <div class="template-art-copy">
                    <span></span>
                    <span></span>
                    <span></span>
                    <span></span>
                  </div>
                  <div class="template-art-media">
                    <span></span>
                    <span></span>
                    <span></span>
                  </div>
                </div>
                <div class="template-art-rhythm" aria-hidden="true">
                  {templateCard.sections.filter((section) => section.slot === 'main').slice(0, 8).map((section) => (
                    <span
                      class={`wireframe-segment wireframe-segment-${section.slot} wireframe-schema-${section.schemaTypeClassName}${section.required ? ' wireframe-segment-required' : ''}`}
                      data-schema={section.schemaType}
                      data-component={section.componentClassName}
                    >
                      <span></span>
                    </span>
                  ))}
                </div>
                <div class="template-art-footer" aria-hidden="true">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
              </div>
              <p class="eyebrow">{templateCard.id}</p>
              <h3>{templateCard.name}</h3>
              <p>{templateCard.heroLead}</p>
              <dl class="compact-meta template-meta">
                <div>
                  <dt>Audience</dt>
                  <dd>{templateCard.audienceLabel}</dd>
                </div>
                <div>
                  <dt>Layout</dt>
                  <dd>{templateCard.layoutLabel}</dd>
                </div>
                <div>
                  <dt>Default theme</dt>
                  <dd>{templateCard.theme.displayName}</dd>
                </div>
                <div>
                  <dt>Hero treatment</dt>
                  <dd>{templateCard.visual.heroLayout} · {templateCard.visual.mediaShape}</dd>
                </div>
                <div>
                  <dt>Required sections</dt>
                  <dd>{templateCard.requiredSectionCount}</dd>
                </div>
                <div>
                  <dt>Total sections</dt>
                  <dd>{templateCard.sections.length}</dd>
                </div>
              </dl>
              <ul class="tag-list" aria-label={`${templateCard.name} tags`}>
                {templateCard.tags.map((tag) => <li>{tag}</li>)}
              </ul>
              <div class="button-row card-actions">
                <a
                  class="button button-primary"
                  href={templateCard.canonicalPath}
                  aria-label={`Open ${templateCard.name} prototype website`}
                >
                  Open prototype website
                </a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</SiteLayout>
