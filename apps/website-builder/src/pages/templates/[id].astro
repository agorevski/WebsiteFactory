---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getTemplatePrototypes, type TemplatePrototype } from '../../lib/templatePrototypes';

export function getStaticPaths() {
  return getTemplatePrototypes().map((prototype) => ({
    params: { id: prototype.id },
    props: { prototype }
  }));
}

interface Props {
  prototype: TemplatePrototype;
}

const { prototype } = Astro.props;
const prototypeClassName = ['template-prototype-site', ...prototype.theme.classNames].join(' ');
const prototypeStyle = [
  prototype.theme.cssText,
  `--template-section-count: ${prototype.sections.length};`,
  `--template-required-ratio: ${prototype.visual.requiredRatio.toFixed(3)};`
].join('\n');
const canonicalPath = prototype.canonicalPath;
---
<SiteLayout title={prototype.pageTitle} description={prototype.pageDescription} canonicalPath={canonicalPath}>
  <div
    class={prototypeClassName}
    style={prototypeStyle}
    data-layout={prototype.visual.layout}
    data-audience={prototype.visual.audience}
    data-hero-layout={prototype.visual.heroLayout}
    data-media-shape={prototype.visual.mediaShape}
    data-nav-layout={prototype.visual.navigationLayout}
    data-footer-layout={prototype.visual.footerLayout}
    data-footer-density={prototype.visual.footerDensity}
  >
    <div class="prototype-shell">
      <aside class="prototype-banner" aria-label="Template prototype notice">
        <span>{prototype.name} template prototype · {prototype.theme.displayName}</span>
        <a href="/#templates">Back to templates</a>
      </aside>

      <header class="prototype-site-header">
        <a class="prototype-site-brand" href={canonicalPath}>
          <span>{prototype.brandName}</span>
        </a>
        <nav class="prototype-site-nav" aria-label="Prototype sections">
          <a href="#template-overview">Overview</a>
          <a href="#template-rhythm">Rhythm</a>
          {prototype.navItems.map((item) => <a href={item.href}>{item.label}</a>)}
          <a href="#template-contact">Contact</a>
        </nav>
      </header>

      <main id="main-content">
      <section class="prototype-site-hero" id="template-overview" aria-labelledby="prototype-title">
          <div>
            <p class="eyebrow">{prototype.eyebrow}</p>
            <h1 id="prototype-title">{prototype.heroTitle}</h1>
            <p>{prototype.heroLead}</p>
            <div class="prototype-hero-actions">
              <a class="prototype-button prototype-button-primary" href="#template-rhythm">Explore rhythm</a>
              <a class="prototype-button prototype-button-secondary" href="/#templates">Compare templates</a>
            </div>
            <ul class="tag-list" aria-label={`${prototype.name} template tags`}>
              {prototype.tags.map((tag) => <li>{tag}</li>)}
            </ul>
          </div>
          <aside class="prototype-hero-card" aria-labelledby="prototype-meta-title">
            <div class="prototype-hero-visual" role="img" aria-label={`${prototype.name} ${prototype.theme.displayName} themed website preview`}>
              <div class="prototype-visual-nav" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <div class="prototype-visual-stage" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
              </div>
              <div class="prototype-visual-cards" aria-hidden="true">
                {prototype.sections.filter((section) => section.slot === 'main').slice(0, 4).map((section) => (
                  <span data-schema={section.schemaType}></span>
                ))}
              </div>
            </div>
            <h2 id="prototype-meta-title">Prototype defaults</h2>
            <dl class="prototype-template-meta">
              {prototype.metrics.map((item) => (
                <div>
                  <dt>{item.term}</dt>
                  <dd>{item.description}</dd>
                </div>
              ))}
            </dl>
          </aside>
        </section>

        <section class="prototype-section" id="template-rhythm" aria-labelledby="template-rhythm-title">
          <p class="eyebrow">Template rhythm</p>
          <h2 id="template-rhythm-title">Sections render in registry order</h2>
          <p>
            This prototype turns the registered template metadata into a complete website-like flow with header, hero,
            content rhythm, conversion callout, and footer. Each section below follows the template order and shows its
            schema type, component variant, purpose, and required/optional status.
          </p>
          <div class="prototype-rhythm-strip" role="img" aria-label={prototype.rhythmLabel}>
            {prototype.sections.map((section) => (
              <span
                class={`prototype-rhythm-item prototype-rhythm-${section.slot}${section.required ? ' prototype-rhythm-required' : ''}`}
                data-schema={section.schemaType}
                aria-hidden="true"
              ></span>
            ))}
          </div>
        </section>

        {prototype.sections.map((section) => (
          <section
            class={`prototype-section prototype-section-${section.schemaTypeClassName}`}
            id={section.fragmentId}
            aria-labelledby={`${section.fragmentId}-title`}
            data-slot={section.slot}
            data-schema={section.schemaType}
            data-component={section.componentClassName}
            data-required={section.required ? 'true' : 'false'}
          >
            <div class="prototype-section-layout">
              <div class="prototype-section-copy">
                <p class="eyebrow">{section.eyebrow}</p>
                <h2 id={`${section.fragmentId}-title`}>{section.heading}</h2>
                <p><strong>{section.purposeLabel}:</strong> {section.purpose}</p>
                <dl class="prototype-template-meta">
                  {section.meta.map((item) => (
                    <div>
                      <dt>{item.term}</dt>
                      <dd>{item.description}</dd>
                    </div>
                  ))}
                </dl>
              </div>
              <div class="prototype-section-preview" role="img" aria-label={section.visualLabel}>
                <span class="prototype-section-preview-kicker" aria-hidden="true">{section.schemaType}</span>
                <div class="prototype-section-preview-main" aria-hidden="true">
                  {section.previewItems.map((item) => <span>{item}</span>)}
                </div>
              </div>
            </div>
            <div class="prototype-section-grid">
              {section.details.map((detail) => (
                <article class={`prototype-section-card ${section.required ? 'prototype-section-required' : 'prototype-section-optional'}`}>
                  <h3>{detail.title}</h3>
                  <p>{detail.body}</p>
                </article>
              ))}
            </div>
          </section>
        ))}

        <section class="prototype-callout" id="template-contact" aria-labelledby="template-contact-title">
          <div>
            <p class="eyebrow">Next step</p>
            <h2 id="template-contact-title">Use this rhythm when your content matches the template.</h2>
            <p>
              Start from schema-first content, then let Website Factory pair the {prototype.name} template with the
              {' '}{prototype.theme.displayName} default theme.
            </p>
          </div>
          <a href="/#templates">Compare templates</a>
        </section>
      </main>

      <footer class="prototype-footer">
        <p><strong>{prototype.brandName}</strong> · {prototype.audienceLabel} · {prototype.layoutLabel}</p>
        <p>{prototype.requiredSectionCount} required sections, {prototype.optionalSectionCount} optional sections.</p>
        <a href="/#templates">Back to template catalog</a>
      </footer>
    </div>
  </div>
</SiteLayout>
