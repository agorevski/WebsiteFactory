---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getExampleSites } from '../../lib/examples';
import { formatPageTitle, getNestedPages, getPageSections, pageDescription, pageHref, pagePathToRouteParam, type UniversalPage } from '../../lib/pages';
import type { UniversalSite } from '../../lib/schema';
import UniversalLandingPage from '../../templates/UniversalLandingPage.astro';

export async function getStaticPaths() {
  const sites = await getExampleSites();

  return sites.flatMap((site) => getNestedPages(site).map((page) => {
    const sections = getPageSections(site, page);

    return {
      params: { slug: site.slug, page: pagePathToRouteParam(page.path) },
      props: { site, page, sections },
    };
  }));
}

interface Props {
  site: UniversalSite;
  page: UniversalPage;
  sections: UniversalSite['sections'];
}

const { site, page, sections } = Astro.props;
---
<SiteLayout title={formatPageTitle(site, page)} description={pageDescription(site, page, sections)} site={site} canonicalPath={pageHref(site, page)}>
  <UniversalLandingPage site={site} page={page} sections={sections} />
</SiteLayout>
