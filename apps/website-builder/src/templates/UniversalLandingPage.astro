---
import Hero from '../components/Hero';
import SectionRenderer from '../components/SectionRenderer';
import SiteFooter from '../components/SiteFooter';
import SiteHeader from '../components/SiteHeader';
import { formatPageLabel, normalizePagePath, type UniversalPage } from '../lib/pages';
import type { UniversalSection, UniversalSite } from '../lib/schema';
import { templateThemeClassName } from '../lib/theme';

interface Props {
  site: UniversalSite;
  page?: UniversalPage;
  sections?: UniversalSection[];
}

const { site, page } = Astro.props;
const sections = Astro.props.sections ?? site.sections;
const isRootPage = !page || normalizePagePath(page.path) === '/';
const pageHero = isRootPage ? site.hero : {
  eyebrow: site.business.name,
  title: page ? formatPageLabel(page) : site.hero.title,
  summary: sections[0]?.summary ?? site.business.description,
  primaryCta: site.hero.primaryCta,
  secondaryCta: {
    label: 'Back to home',
    href: `/${site.slug}/`,
    variant: 'secondary' as const,
  },
};
---
<div class={`site-shell ${templateThemeClassName(site)} radius-${site.theme.radius}`}>
  <SiteHeader site={site} />
  <main>
    <Hero business={site.business} hero={pageHero} theme={site.theme} variant={isRootPage ? 'landing' : 'page'} />
    <SectionRenderer cta={site.ctas?.final} sections={sections} />
  </main>
  <SiteFooter site={site} />
</div>
