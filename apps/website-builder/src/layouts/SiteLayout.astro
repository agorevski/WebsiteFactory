---
import '../styles/global.css';
import type { UniversalSite } from '../lib/schema';
import { siteThemeClassNames, siteThemeCssText } from '../lib/theme';

interface Props {
  title: string;
  description: string;
  site?: UniversalSite;
  canonicalPath?: string;
  noIndex?: boolean;
}

const { title, description, site, canonicalPath: canonicalPathProp, noIndex = false } = Astro.props;
const canonicalPath = canonicalPathProp ?? site?.seo.canonicalPath ?? Astro.url.pathname;
const themeClass = siteThemeClassNames(site);
const themeCssText = siteThemeCssText(site);
const jsonLd = site ? {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: site.business.name,
  description: site.business.description,
  telephone: site.business.phone,
  email: site.business.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.business.address.street,
    addressLocality: site.business.address.city,
    addressRegion: site.business.address.region,
    postalCode: site.business.address.postalCode,
    addressCountry: site.business.address.country,
  },
  areaServed: site.business.areaServed,
} : undefined;
---
<!doctype html>
<html lang="en" class={themeClass} style={themeCssText}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noIndex ? <meta name="robots" content="noindex,nofollow" /> : null}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonicalPath} />
    <title>{title}</title>
    {jsonLd ? <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} /> : null}
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <slot />
  </body>
</html>
