{
  "name": "@website-factory/components",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Reusable semantic React section components for Website Factory sites.",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": ">=19.0.0"
  },
  "dependencies": {
    "@website-factory/schema": "0.1.0",
    "@website-factory/themes": "0.1.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  }
}
