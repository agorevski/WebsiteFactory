{
  "name": "website-factory",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "_workspaces:present": "test -n \"$(find apps packages -mindepth 2 -maxdepth 2 -name package.json -print -quit 2>/dev/null)\"",
    "build": "node scripts/build-workspaces.mjs",
    "typecheck": "if npm run _workspaces:present --silent; then npm run typecheck --workspaces --if-present; else echo \"No workspace type checks configured yet.\"; fi",
    "lint": "echo \"No linting configured yet.\"",
    "validate": "npm run typecheck && npm run lint && npm run build && npm run validate:examples",
    "validate:examples": "npm run validate:examples --workspace @website-factory/website-builder",
    "qa:generated:build": "npm run build",
    "qa:generated:serve": "npm run preview --workspace @website-factory/website-builder -- --host 127.0.0.1 --port 4173",
    "qa:generated:lhci": "node scripts/run-lhci.mjs",
    "qa:generated:playwright": "node scripts/playwright-axe-smoke.mjs",
    "qa:generated:static": "node scripts/validate-static-site.mjs --skip-html-validator",
    "qa:generated:html": "node scripts/validate-static-site.mjs --skip-linkinator",
    "qa:generated": "npm run qa:generated:build && start-server-and-test \"npm run qa:generated:serve\" http://127.0.0.1:4173 \"npm run qa:generated:lhci && npm run qa:generated:playwright && npm run qa:generated:static\"",
    "qa:generated:report": "./scripts/run-generated-qa.sh",
    "clean": "rm -rf dist .astro apps/*/dist apps/*/.astro packages/*/dist packages/*/*.tsbuildinfo",
    "regenerate:websites": "./scripts/regenerate-websites.sh"
  },
  "devDependencies": {
    "@astrojs/react": "^6.0.1",
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "^0.15.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.6",
    "html-validator-cli": "^7.0.1",
    "linkinator": "^7.6.1",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "start-server-and-test": "^3.0.11",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
